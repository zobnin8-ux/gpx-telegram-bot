{
  "name": "gpx-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot that turns uploaded GPX files into a public Leaflet map with NM/kt metrics.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0",
    "telegraf": "^4.16.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/node-fetch": "^2.6.11",
    "@types/xml2js": "^0.4.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
